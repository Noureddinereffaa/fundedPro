# ══════════════════════════════════════════════════════════════════
# Pro FundX — Production Environment Variables
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in EVERY value before deploying.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Domain ────────────────────────────────────────────────────────
# Your production domain (without trailing slash)
CLIENT_URL=https://your-domain.com
API_URL=https://your-domain.com/api
NGINX_HOST=your-domain.com

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://pro-fundx:CHANGE_ME_STRONG_PASSWORD@postgres:5432/pro-fundx?schema=public
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT Secrets ───────────────────────────────────────────────────
# REQUIRED — use 64+ random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_MIN_64_CHARS_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_MIN_64_CHARS_RANDOM_STRING_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────────────
# Redis is used for WS price state coordination
REDIS_URL=redis://redis:6379

# ── SMTP (Email) ──────────────────────────────────────────────────
# Example using Gmail App Password. For production use a dedicated
# transactional email provider (Resend, Postmark, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-noreply@your-domain.com
SMTP_PASS=your-app-specific-password

# ── Market Data ───────────────────────────────────────────────────
# Get a free key at https://twelvedata.com
TWELVEDATA_API_KEY=your_twelve_data_api_key_here

# ── Crypto Wallets ────────────────────────────────────────────────
# IMPORTANT: Replace with YOUR actual wallets before accepting payments!
BTC_WALLET=bc1q_YOUR_REAL_BTC_WALLET_ADDRESS
ETH_WALLET=0x_YOUR_REAL_ETH_WALLET_ADDRESS
USDT_TRC20_WALLET=T_YOUR_REAL_TRON_USDT_WALLET_ADDRESS
USDT_ERC20_WALLET=0x_YOUR_REAL_ERC20_USDT_WALLET_ADDRESS

# ── Frontend (Vite) ───────────────────────────────────────────────
# These are embedded into the frontend bundle at build time
VITE_API_URL=https://your-domain.com/api
VITE_WS_URL=wss://your-domain.com/ws

# ── Sentry (Error Monitoring) ─────────────────────────────────────
# Get a free DSN at https://sentry.io
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxxxxx
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxxxxx

# ── Server ────────────────────────────────────────────────────────
API_PORT=3001
WS_PORT=3002
NODE_ENV=production
SERVER_TIMEZONE_OFFSET=3

# ── Backup ────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30

# ══════════════════════════════════════════════════════════════════
# DEPLOYMENT CHECKLIST
# ══════════════════════════════════════════════════════════════════
# Before going live:
# [ ] Replace ALL CHANGE_ME and placeholder values above
# [ ] Run: openssl req -x509 ... OR use Certbot for real SSL
# [ ] Run: npm run build in project root
# [ ] Run: docker-compose --profile production up -d
# [ ] Visit https://your-domain.com/health to verify API is running
# [ ] Run: cd api && npx prisma migrate deploy (first deploy only)
# [ ] Run: cd api && npm run make:admin (create first admin user)
# ══════════════════════════════════════════════════════════════════
