{
  "name": "pro-fundx",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd api && npm run dev",
    "dev:ws": "cd server && npm run start",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\" \"npm run dev:ws\"",
    "build": "vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "start": "start.bat",
    "stop": "stop.bat",
    "status": "status.bat",
    "start:frontend": "start.bat --frontend",
    "start:api": "start.bat --api",
    "start:ws": "start.bat --ws",
    "test:markets": "node test-markets.js",
    "test:ui": "node test-ui-markets.js",
    "test:all": "node test-markets.js && node test-ui-markets.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"server/**/*.js\" \"api/src/**/*.ts\" \"shared/**/*.{js,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"server/**/*.js\" \"api/src/**/*.ts\" \"shared/**/*.{js,ts}\"",
    "backup": "bash scripts/backup.sh",
    "backup:win": "powershell -ExecutionPolicy Bypass -File scripts/backup.ps1",
    "backup:restore": "bash scripts/restore.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^10.65.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.9",
    "react-router-dom": "^7.18.1",
    "react-virtuoso": "^4.18.10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "happy-dom": "^20.10.6",
    "oxlint": "^1.69.0",
    "prettier": "^3.9.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
