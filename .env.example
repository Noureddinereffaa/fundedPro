# Database
DATABASE_URL=postgresql://fundedpro:CHANGE_ME_DB_PASSWORD@localhost:5432/fundedpro?schema=public

# Redis (for WS server state coordination — optional, falls back to in-memory)
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379

# JWT (REQUIRED: min 32 characters — use 64+ random hex in production)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-at-least-32-chars-long-secret
JWT_REFRESH_SECRET=change-me-to-another-at-least-32-chars-long-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Twelve Data (for forex data)
TWELVEDATA_API_KEY=your_twelve_data_api_key

# Client URLs
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:3001

# Frontend env (VITE_ prefix)
VITE_API_URL=http://localhost:3001/api
VITE_WS_URL=ws://localhost:3002

# Database Backup (retention in days)
BACKUP_RETENTION_DAYS=30

# Sentry (error monitoring — get DSN from https://sentry.io)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxxxxx
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxxxxx

# Server
API_PORT=3001
WS_PORT=3002
NODE_ENV=development