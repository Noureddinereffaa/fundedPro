# Database
DATABASE_URL=postgresql://fundedpro:changeme@localhost:5432/fundedpro?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Twelve Data (for forex data)
TWELVEDATA_API_KEY=your_twelve_data_api_key

# Client URLs
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:3001

# Server
PORT=3001
NODE_ENV=development