# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values
# Generate JWT secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ══════════════════════════════════════════════════════════════

DATABASE_URL=postgresql://fundedpro:CHANGE_ME_DB_PASSWORD@localhost:5432/fundedpro?schema=public

# JWT Secrets — MUST be 64-char hex strings
JWT_SECRET=change-me-to-a-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

CLIENT_URL=http://localhost:5173
API_URL=http://localhost:3001
API_PORT=3001
NODE_ENV=development

# Optional: Redis for price caching (falls back to in-memory)
REDIS_URL=

# Optional: WebSocket server URL (defaults to http://localhost:3002)
WS_SERVER_URL=

# Crypto wallets for payment (admin fills these in production)
BTC_WALLET=
ETH_WALLET=
USDT_TRC20_WALLET=
USDT_ERC20_WALLET=
