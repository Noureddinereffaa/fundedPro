generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ──────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  phone               String?
  country             String?
  avatar              String?
  emailVerified       Boolean   @default(false) @map("email_verified")
  emailVerifyToken    String?   @map("email_verify_token")
  emailVerifyExpires  DateTime? @map("email_verify_expires")
  resetPasswordToken  String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  kycStatus           String    @default("none") @map("kyc_status")
  kycDocuments        Json?     @map("kyc_documents")
  role                String    @default("user")
  loginAttempts       Int       @default(0) @map("login_attempts")
  lockUntil           DateTime? @map("lock_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  accounts            Account[]
  payments            Payment[]
  payoutRequests      PayoutRequest[]
  refreshTokens       RefreshToken[]
  alerts              Alert[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  userBadges          UserBadge[]

  @@index([resetPasswordToken])
  @@index([emailVerifyToken])
  @@map("users")
}

// ── Badges / Achievements ────────────────────────────────────

model Badge {
  id          String   @id @default(uuid())
  key         String   @unique
  category    String   // progression | volume | profit | streak | risk | consistency | special
  tier        Int      @default(1) // 1= bronze, 2= silver, 3= gold, 4= platinum
  name        String
  description String
  icon        String   // emoji character
  criteria    Json     // { type: "trades_count" | "profit" | "win_streak" | "trading_days" | "passed_evaluation" | "funded" | "payout" | "no_violations", value: number }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  badgeId    String    @map("badge_id")
  progress   Float     @default(0) // 0.0 → 1.0
  unlocked   Boolean   @default(false)
  unlockedAt DateTime? @map("unlocked_at")
  metadata   Json?     // { currentValue: number, targetValue: number, ... }

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([unlocked])
  @@map("user_badges")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  userAgent String?  @map("user_agent")
  ip        String?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Accounts ───────────────────────────────────────────────

model Account {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  accountType   String   @map("account_type")
  accountSize   Decimal  @map("account_size") @db.Decimal(12, 2)
  balance       Decimal  @db.Decimal(12, 2)
  equity        Decimal  @db.Decimal(12, 2)
  currency      String   @default("USD")
  platform      String   @default("Pro FundX")
  login         String?
  password      String?  @map("account_password")
  server        String?
  status        String   @default("active")
  phase         String?
  leverage      Int      @default(100)
  profitTarget  Decimal? @map("profit_target") @db.Decimal(5, 2)
  maxDailyLoss  Decimal? @map("max_daily_loss") @db.Decimal(5, 2)
  maxOverallLoss Decimal? @map("max_overall_loss") @db.Decimal(5, 2)
  maxPositionSize Decimal? @map("max_position_size") @db.Decimal(5, 2)
  maxOpenTrades Int?     @map("max_open_trades")
  minTradingDays Int?    @map("min_trading_days")
  maxTradingDays Int?    @map("max_trading_days")
  tradingDaysCount Int   @default(0) @map("trading_days_count")
   lastTradingDay  DateTime? @map("last_trading_day")
   startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  passedAt      DateTime? @map("passed_at")
  failedAt      DateTime? @map("failed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id])
  positions       Position[]
  trades          Trade[]
  orders          Order[]
  payments        Payment[]
  payoutRequests  PayoutRequest[]
  violations      RuleViolation[]
  dailySnapshots  DailySnapshot[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("accounts")
}

// ── Orders ─────────────────────────────────────────────────

model Order {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  symbol        String
  type          String
  side          String
  volume        Decimal  @db.Decimal(10, 4)
  price         Decimal? @db.Decimal(14, 8)
  stopPrice     Decimal? @map("stop_price") @db.Decimal(14, 8)
  stopLoss      Decimal? @map("stop_loss") @db.Decimal(14, 8)
  takeProfit    Decimal? @map("take_profit") @db.Decimal(14, 8)
  trailingStop  Decimal? @map("trailing_stop") @db.Decimal(14, 8)
  trailingStep  Decimal? @map("trailing_step") @db.Decimal(14, 8)
  breakEven     Boolean  @default(false)
  timeInForce   String   @default("gtc") @map("time_in_force")
  status        String   @default("pending")
  filledVolume  Decimal? @map("filled_volume") @db.Decimal(10, 4)
  filledPrice   Decimal? @map("filled_price") @db.Decimal(14, 8)
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  position Position?

  @@index([accountId])
  @@index([status])
  @@index([accountId, createdAt])
  @@map("orders")
}

// ── Positions ──────────────────────────────────────────────

model Position {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  orderId       String?  @unique @map("order_id")
  symbol        String
  side          String
  volume        Decimal  @db.Decimal(10, 4)
  openPrice     Decimal  @map("open_price") @db.Decimal(14, 8)
  currentPrice  Decimal? @map("current_price") @db.Decimal(14, 8)
  stopLoss      Decimal? @map("stop_loss") @db.Decimal(14, 8)
  takeProfit    Decimal? @map("take_profit") @db.Decimal(14, 8)
  trailingStop  Decimal? @map("trailing_stop") @db.Decimal(14, 8)
  trailingStep  Decimal? @map("trailing_step") @db.Decimal(14, 8)
  breakEven     Boolean  @default(false)
  swap          Decimal  @default(0) @db.Decimal(12, 2)
  commission    Decimal  @default(0) @db.Decimal(12, 2)
  profit        Decimal  @default(0) @db.Decimal(12, 2)
  margin        Decimal  @default(0) @db.Decimal(12, 2)
  status        String   @default("open")
  openTime      DateTime @default(now()) @map("open_time")
  closeTime     DateTime? @map("close_time")
  closePrice    Decimal? @map("close_price") @db.Decimal(14, 8)
  closeReason   String?  @map("close_reason")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  order   Order?  @relation(fields: [orderId], references: [id])
  trade   Trade?

  @@index([accountId])
  @@index([orderId])
  @@index([status])
  @@index([symbol, status])
  @@map("positions")
}

// ── Trades ─────────────────────────────────────────────────

model Trade {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  positionId  String   @unique @map("position_id")
  symbol      String
  side        String
  volume      Decimal  @db.Decimal(10, 4)
  openPrice   Decimal  @map("open_price") @db.Decimal(14, 8)
  closePrice  Decimal  @map("close_price") @db.Decimal(14, 8)
  profit      Decimal  @db.Decimal(12, 2)
  swap        Decimal  @default(0) @db.Decimal(12, 2)
  commission  Decimal  @default(0) @db.Decimal(12, 2)
  duration    Int?
  openTime    DateTime @map("open_time")
  closeTime   DateTime @map("close_time")
  closeReason String?  @map("close_reason")
  createdAt   DateTime @default(now()) @map("created_at")

  account  Account  @relation(fields: [accountId], references: [id])
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([positionId])
  @@index([closeTime])
  @@index([accountId, closeTime])
  @@map("trades")
}

// ── Rule Violations ────────────────────────────────────────

model RuleViolation {
  id           String @id @default(uuid())
  accountId    String @map("account_id")
  ruleType     String @map("rule_type")
  description  String?
  violationData Json? @map("violation_data")
  createdAt    DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("rule_violations")
}

// ── Payments ───────────────────────────────────────────────

model Payment {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  accountId       String?  @map("account_id")
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("USD")
  method          String?  @default("crypto")
  walletAddress   String?  @map("wallet_address")
  network         String?  // BTC, ETH, USDT-TRC20, USDT-ERC20
  txHash          String?  @map("tx_hash")
  confirmations   Int      @default(0)
  metadata        Json?
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([accountId])
  @@map("payments")
}

// ── Payout Requests ────────────────────────────────────────

model PayoutRequest {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  accountId String   @map("account_id")
  amount    Decimal  @db.Decimal(12, 2)
  method    String?
  walletAddress String? @map("wallet_address")
  txHash    String?  @map("tx_hash")
  status    String   @default("pending")
  processedAt DateTime? @map("processed_at")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([status])
  @@map("payout_requests")
}

// ── Daily Snapshots ────────────────────────────────────────

model DailySnapshot {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  date      DateTime @db.Date
  balance   Decimal  @db.Decimal(12, 2)
  equity    Decimal  @db.Decimal(12, 2)
  dailyPnl  Decimal  @default(0) @map("daily_pnl") @db.Decimal(12, 2)
  totalPnl  Decimal  @default(0) @map("total_pnl") @db.Decimal(12, 2)
  openPositions Int  @default(0) @map("open_positions")
  margin    Decimal  @default(0) @db.Decimal(12, 2)
  freeMargin Decimal @default(0) @map("free_margin") @db.Decimal(12, 2)
  marginLevel Decimal? @map("margin_level") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@map("daily_snapshots")
}

// ── Alerts ─────────────────────────────────────────────────

model Alert {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  symbol    String
  condition String   // 'above' | 'below'
  price     Decimal  @db.Decimal(14, 8)
  message   String?
  status    String   @default("active") // 'active' | 'triggered' | 'deleted'
  triggeredAt DateTime? @map("triggered_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("alerts")
}

// ── Notifications ──────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // 'alert_triggered' | 'payout_processed' | 'violation' | 'account_update' | 'system'
  title     String
  message   String?
  data      Json?
  link      String?  // optional navigation link
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

// ── Audit Log ──────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String   // 'approve_payment' | 'reject_payment' | 'update_rules' | 'update_user' | 'update_account'
  target    String?  // e.g. user email, payment id, account id
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Trading Rules Config ───────────────────────────────────

model TradingRuleConfig {
  id              String   @id @default(uuid())
  accountSize     Decimal  @map("account_size") @db.Decimal(12, 2)
  phase           String
  profitTarget    Decimal  @map("profit_target") @db.Decimal(5, 2)
  maxDailyLoss    Decimal  @map("max_daily_loss") @db.Decimal(5, 2)
  maxOverallLoss  Decimal  @map("max_overall_loss") @db.Decimal(5, 2)
  maxPositionSize Decimal  @map("max_position_size") @db.Decimal(5, 2)
  maxLeverage     Int      @map("max_leverage")
  maxOpenTrades   Int      @map("max_open_trades")
  minTradingDays  Int      @map("min_trading_days")
  maxTradingDays  Int      @map("max_trading_days")
  commission      Decimal  @default(0) @db.Decimal(8, 2)
  spreadMarkup    Decimal  @default(0) @map("spread_markup") @db.Decimal(8, 2)
   newsRestriction Boolean  @default(false) @map("news_restriction")
   createdAt       DateTime @default(now()) @map("created_at")

  @@unique([accountSize, phase])
  @@map("trading_rule_configs")
}

// ── Coupons ────────────────────────────────────────────────

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  discountType    String   @default("percentage") // 'percentage' | 'fixed'
  discountValue   Decimal  @db.Decimal(12, 2)
  maxUses         Int?     @map("max_uses")
  usedCount       Int      @default(0) @map("used_count")
  expiresAt       DateTime? @map("expires_at")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("coupons")
}

// ── Platform Settings & Contact ──────────────────────────────────────────────

model PlatformSetting {
  key         String   @id
  value       String   @db.Text
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("unread") // unread | read | resolved
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

// ═══════════════════════════════════════════════════════════════
// MARKET DATA — TimescaleDB hypertables
// ═══════════════════════════════════════════════════════════════
// These tables are designed to be converted to TimescaleDB
// hypertables via raw SQL after migration:
//   SELECT create_hypertable('candles', 'timestamp', chunk_time_interval => INTERVAL '1 day');
//   SELECT create_hypertable('ticks', 'timestamp', chunk_time_interval => INTERVAL '1 hour');
//   SELECT create_hypertable('market_snapshots', 'timestamp', chunk_time_interval => INTERVAL '1 day');

model Candle {
  id         BigInt   @id @default(autoincrement())
  symbol     String
  resolution String   // 1m, 5m, 15m, 30m, 1h, 4h, 1d, 1w, 1M
  timestamp  DateTime
  open       Decimal  @db.Decimal(14, 8)
  high       Decimal  @db.Decimal(14, 8)
  low        Decimal  @db.Decimal(14, 8)
  close      Decimal  @db.Decimal(14, 8)
  volume     Decimal  @db.Decimal(18, 8)
  trades     Int?
  provider   String   @default("ccxt")

  @@unique([symbol, resolution, timestamp])
  @@index([symbol, resolution, timestamp])
  @@index([timestamp])
  @@map("candles")
}

model Tick {
  id        BigInt   @id @default(autoincrement())
  symbol    String
  price     Decimal  @db.Decimal(14, 8)
  bid       Decimal  @db.Decimal(14, 8)
  ask       Decimal  @db.Decimal(14, 8)
  volume    Decimal  @db.Decimal(18, 8)
  timestamp DateTime
  provider  String   @default("ccxt")

  @@index([symbol, timestamp])
  @@index([timestamp])
  @@map("ticks")
}

model MarketSnapshot {
  id         BigInt   @id @default(autoincrement())
  symbol     String
  marketType String   @map("market_type") // crypto, forex, metals, indices, stocks
  price      Decimal  @db.Decimal(14, 8)
  bid        Decimal  @db.Decimal(14, 8)
  ask        Decimal  @db.Decimal(14, 8)
  high24h    Decimal? @db.Decimal(14, 8)
  low24h     Decimal? @db.Decimal(14, 8)
  volume24h  Decimal? @db.Decimal(18, 8)
  change24h  Decimal? @db.Decimal(8, 4)
  timestamp  DateTime
  provider   String   @default("ccxt")

  @@index([symbol, timestamp])
  @@index([marketType, timestamp])
  @@index([timestamp])
  @@map("market_snapshots")
}

model SymbolMeta {
  id              String   @id // e.g. "BTC/USDT", "EUR/USD"
  symbol          String   @unique
  name            String
  description     String?
  marketType      String   @map("market_type")
  baseCurrency    String   @map("base_currency")
  quoteCurrency   String   @map("quote_currency")
  precision       Int      @default(2)
  minLot          Decimal  @default(0.01) @db.Decimal(12, 4)
  lotStep         Decimal  @default(0.01) @db.Decimal(12, 4)
  pipValue        Decimal  @default(0.01) @db.Decimal(8, 4)
  contractSize    Int      @default(1)
  sessionOpen     String?  @map("session_open")
  sessionClose    String?  @map("session_close")
  sessionTz       String?  @map("session_timezone")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([marketType])
  @@index([isActive])
  @@map("symbol_meta")
}

model EconomicEvent {
  id          String   @id @default(uuid())
  title       String
  country     String
  date        DateTime
  impact      String   // low | medium | high
  forecast    String?
  previous    String?
  actual      String?
  description String?
  source      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([date])
  @@index([country, date])
  @@index([impact, date])
  @@map("economic_events")
}
