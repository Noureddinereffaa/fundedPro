# ── Database Backup Configuration ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pro-fundx
DB_USER=pro-fundx
DB_PASSWORD=pro-fundx123

# Backup retention in days (0 = keep forever)
BACKUP_RETENTION_DAYS=30

# Optional: S3-compatible storage (for production off-site backup)
# BACKUP_S3_BUCKET=my-bucket/backups
# BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: Backup notification email (via existing SMTP config)
# BACKUP_NOTIFY_EMAIL=admin@example.com
